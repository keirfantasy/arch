# ---- Git ----
gcom() {
  git add .
  git commit -m "$1"
}

lazyg() {
  git add .
  git commit -m "$1"
  git push
}

# ---- File Operations ----
cpp() {
  set -e
  strace -q -ewrite cp -- "${1}" "${2}" 2>&1 |
    awk '{
        count += $NF
        if (count % 10 == 0) {
            percent = count / total_size * 100
            printf "%3d%% [", percent
            for (i=0;i<=percent;i++)
                printf "="
            printf ">"
            for (i=percent;i<100;i++)
                printf " "
            printf "]\r"
        }
    }
    END { print "" }' total_size="$(stat -c '%s' "${1}")" count=0
}

# ---- System Info ----
whatismyip() {
  local iface
  iface=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
  echo -n "Internal IP: "
  if [ -n "$iface" ]; then
    ip addr show "$iface" 2>/dev/null | grep "inet " | awk '{print $2}' | cut -d/ -f1 || echo "N/A"
  else
    echo "N/A"
  fi
  echo -n "External IP: "
  curl -4 ifconfig.me 2>/dev/null || echo "N/A"
}

# ---- Archives ----
extract() {
  for archive in "$@"; do
    if [ -f "$archive" ]; then
      case $archive in
      *.tar.bz2) tar xvjf $archive ;;
      *.tar.gz) tar xvzf $archive ;;
      *.bz2) bunzip2 $archive ;;
      *.rar) rar x $archive ;;
      *.gz) gunzip $archive ;;
      *.tar) tar xvf $archive ;;
      *.tbz2) tar xvjf $archive ;;
      *.tgz) tar xvzf $archive ;;
      *.zip) unzip $archive ;;
      *.Z) uncompress $archive ;;
      *.7z) 7z x $archive ;;
      *) echo "don't know how to extract '$archive'..." ;;
      esac
    else
      echo "'$archive' is not a valid file!"
    fi
  done
}

# ---- File Operations ----
cpg() {
  if [ -d "$2" ]; then
    cp "$1" "$2" && cd "$2"
  else
    cp "$1" "$2"
  fi
}

mvg() {
  if [ -d "$2" ]; then
    mv "$1" "$2" && cd "$2"
  else
    mv "$1" "$2"
  fi
}

mkdirg() {
  mkdir -p "$1"
  cd "$1"
}

# ---- Text Utilities ----
trim() {
  local var=$*
  var="${var#"${var%%[![:space:]]*}"}"
  var="${var%"${var##*[![:space:]]}"}"
  echo -n "$var"
}

# ---- Navigation ----
cd() {
  builtin cd -- "$@" && ls -lAh
}

up() {
  local limit=${1:-1}
  local d=""
  for ((i = 1; i <= limit; i++)); do
    d="$d/.."
  done
  d=${d#/}
  [ -z "$d" ] && d=..
  cd "$d" || return
}

# ---- Update and Cleanup ----
update() {
  echo "# ---- update: acquiring root privileges ----"
  sudo -v || {
    echo "# ---- sudo auth needed ----" >&2
    return 1
  }

  echo "# ---- pacman: sync & upgrade ----"
  sudo pacman -Syu --noconfirm

  echo "# ---- pacman: remove orphaned deps ----"
  local orphans
  orphans=$(pacman -Qtdq 2>/dev/null) && sudo pacman -Rns --noconfirm ${(f)orphans}

  echo "# ---- pacman: clean cache ----"
  sudo pacman -Sc --noconfirm

  echo "# ---- journal: vacuum old logs (7d) ----"
  sudo journalctl --vacuum-time=7d 2>/dev/null

  echo "# ---- flatpak: update ----"
  command -v flatpak &>/dev/null && flatpak update -y

  echo "# ---- flatpak: remove unused runtimes ----"
  command -v flatpak &>/dev/null && flatpak uninstall --unused -y

  echo "# ---- rustup: update toolchains ----"
  command -v rustup &>/dev/null && rustup update

  echo "# ---- npm: update global packages ----"
  command -v npm &>/dev/null && npm update -g 2>/dev/null

  echo "# ---- npm: update user packages ----"
  command -v npm &>/dev/null && npm update --prefix "$HOME/.local" 2>/dev/null

  echo "# ---- pip: update user packages ----"
  command -v pip &>/dev/null && pip install --user --upgrade pip pynvim 2>/dev/null

  echo "# ---- gem: update ----"
  command -v gem &>/dev/null && gem update --user-install --no-document 2>/dev/null

  echo "# ---- lazygit: update ----"
  command -v lazygit &>/dev/null && go install github.com/jesseduffield/lazygit@latest 2>/dev/null

  echo "# ---- starship: self-update ----"
  command -v starship &>/dev/null && starship self-update 2>/dev/null

  echo "# ---- atuin: self-update ----"
  command -v atuin &>/dev/null && atuin self-update 2>/dev/null

  echo "# ---- zoxide: self-update ----"
  command -v zoxide &>/dev/null && curl -sSfL https://webi.sh/zoxide | sh 2>/dev/null

  echo "# ---- uv: self-update ----"
  command -v uv &>/dev/null && uv self update 2>/dev/null

  echo "# ---- composer: global update ----"
  command -v composer &>/dev/null && composer global update 2>/dev/null

  echo "# ---- fzf: update ----"
  command -v fzf &>/dev/null && [ -d ~/.fzf ] && \
    git -C ~/.fzf pull --ff-only 2>/dev/null && ~/.fzf/install --all --no-update-rc 2>/dev/null

  echo "# ---- opencode: update ----"
  command -v opencode &>/dev/null && curl -fsSL https://opencode.ai/install | bash

  echo "# ---- herdr: update ----"
  command -v herdr &>/dev/null && curl -fsSL https://herdr.dev/install.sh | sh

  echo "# ---- All done! ----"
}
